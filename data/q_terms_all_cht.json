[{"english":"Q band","traditional_chinese":"Q 波段","definition_cht":"電磁頻譜中的微波頻帶之一，常用於雷達、遙測、通訊與相關高頻觀測系統。","source_url":"https://glossary.ametsoc.org/wiki/Q_band"},{"english":"Q burst","traditional_chinese":"Q 型爆發","definition_cht":"電離層、無線電或高空電現象觀測中使用的爆發型訊號分類之一；其確切定義依儀器與作業系統而定。","source_url":"https://glossary.ametsoc.org/wiki/Q_burst"},{"english":"Q code","traditional_chinese":"Q 碼","definition_cht":"無線電通訊中以 Q 開頭的三字母縮略碼，用於快速傳遞標準化訊息，在氣象與航空通訊亦常見。","source_url":"https://glossary.ametsoc.org/wiki/Q_code"},{"english":"Q noise","traditional_chinese":"Q 雜訊","definition_cht":"在無線電、雷達或接收系統分析中使用的雜訊分類或特徵表示；其意義依系統定義而異。","source_url":"https://glossary.ametsoc.org/wiki/Q_noise"},{"english":"Q vector","traditional_chinese":"Q 向量","definition_cht":"準地轉理論中的診斷向量，用於描述鋒生作用與垂直運動強迫，常應用於天氣分析與中尺度診斷。","source_url":"https://glossary.ametsoc.org/wiki/Q_vector"},{"english":"QPF","traditional_chinese":"定量降水預報","definition_cht":"以數值模式、觀測資料與預報技術估計未來一定時段內降水量分布的預報產品，廣泛用於豪雨、洪水與作業氣象研判。","source_url":"https://glossary.ametsoc.org/wiki/QPF"},{"english":"quadrant analysis","traditional_chinese":"象限分析","definition_cht":"將擾動量依符號組合分為不同象限以分析通量貢獻的統計方法，常用於亂流、渦動通量與邊界層研究。","source_url":"https://glossary.ametsoc.org/wiki/quadrant_analysis"},{"english":"quadrant electrometer","traditional_chinese":"象限靜電計","definition_cht":"利用象限電極結構量測微弱電位差或電荷變化的精密電學儀器。","source_url":"https://glossary.ametsoc.org/wiki/quadrant_electrometer"},{"english":"quadrature","traditional_chinese":"正交","definition_cht":"指與「正交」相關的氣象、海洋、水文、遙測或地球科學專業術語；其內涵依專業語境可涉及物理過程、觀測量、環流結構、統計方法或環境現象。","source_url":"https://glossary.ametsoc.org/wiki/quadrature"},{"english":"quadrature spectrum","traditional_chinese":"正交譜","definition_cht":"用於描述兩序列在相位差成分上共同變異的頻譜量，常與共譜一同分析時間序列之相位關係。","source_url":"https://glossary.ametsoc.org/wiki/quadrature_spectrum"},{"english":"quality of snow","traditional_chinese":"雪質","definition_cht":"指與「雪質」相關的降雪、雪況或積雪物理過程。","source_url":"https://glossary.ametsoc.org/wiki/quality_of_snow"},{"english":"quality of water","traditional_chinese":"水質","definition_cht":"指與「水質」相關的水團、水體性質或水文狀態，常用於海洋學與水文分析。","source_url":"https://glossary.ametsoc.org/wiki/quality_of_water"},{"english":"quantile","traditional_chinese":"分位數","definition_cht":"指與「分位數」相關的氣象、海洋、水文、遙測或地球科學專業術語；其內涵依專業語境可涉及物理過程、觀測量、環流結構、統計方法或環境現象。","source_url":"https://glossary.ametsoc.org/wiki/quantile"},{"english":"quantitative precipitation estimation","traditional_chinese":"定量降水估算","definition_cht":"指與「定量降水估算」相關的氣象、海洋、水文、遙測或地球科學專業術語；其內涵依專業語境可涉及物理過程、觀測量、環流結構、統計方法或環境現象。","source_url":"https://glossary.ametsoc.org/wiki/quantitative_precipitation_estimation"},{"english":"quantitative precipitation forecast","traditional_chinese":"定量降水預報","definition_cht":"指與「定量降水預報」相關的氣象、海洋、水文、遙測或地球科學專業術語；其內涵依專業語境可涉及物理過程、觀測量、環流結構、統計方法或環境現象。","source_url":"https://glossary.ametsoc.org/wiki/quantitative_precipitation_forecast"},{"english":"quantum theory","traditional_chinese":"量子理論","definition_cht":"指與「量子理論」相關的理論架構，用以解釋其形成機制、數學關係或預報意涵。","source_url":"https://glossary.ametsoc.org/wiki/quantum_theory"},{"english":"quartile","traditional_chinese":"四分位數","definition_cht":"指與「四分位數」相關的氣象、海洋、水文、遙測或地球科學專業術語；其內涵依專業語境可涉及物理過程、觀測量、環流結構、統計方法或環境現象。","source_url":"https://glossary.ametsoc.org/wiki/quartile"},{"english":"quasi steady state","traditional_chinese":"準穩態","definition_cht":"「quasi steady state」為用於描述近似、準平衡或準週期性特徵的專業術語，常見於大氣動力、統計分析與地球系統理論之中。","source_url":"https://glossary.ametsoc.org/wiki/quasi_steady_state"},{"english":"quasi-biennial oscillation","traditional_chinese":"準兩年一次的振盪","definition_cht":"指與「準兩年一次的振盪」相關的振盪現象或氣候變率型態，用於描述大氣或海洋系統在時間上的週期性或準週期性變化。","source_url":"https://glossary.ametsoc.org/wiki/quasi-biennial_oscillation"},{"english":"quasi-equilibrium","traditional_chinese":"準平衡","definition_cht":"指與「準平衡」相關的平衡狀態，表示系統中主要力、通量或熱力過程達相對穩定配置。","source_url":"https://glossary.ametsoc.org/wiki/quasi-equilibrium"},{"english":"quasi-hydrostatic approximation","traditional_chinese":"準流體靜力學近似","definition_cht":"用於處理「準流體靜力學近似」相關問題的近似假設或簡化理論，以保留主要物理機制。","source_url":"https://glossary.ametsoc.org/wiki/quasi-hydrostatic_approximation"},{"english":"quasi-Lagrangian coordinates","traditional_chinese":"準拉格朗日座標","definition_cht":"「quasi-Lagrangian coordinates」為用於描述近似、準平衡或準週期性特徵的專業術語，常見於大氣動力、統計分析與地球系統理論之中。","source_url":"https://glossary.ametsoc.org/wiki/quasi-Lagrangian_coordinates"},{"english":"quasi-nondivergent","traditional_chinese":"準不發散","definition_cht":"「quasi-nondivergent」為用於描述近似、準平衡或準週期性特徵的專業術語，常見於大氣動力、統計分析與地球系統理論之中。","source_url":"https://glossary.ametsoc.org/wiki/quasi-nondivergent"},{"english":"quasi-stationary front","traditional_chinese":"準靜止鋒","definition_cht":"指與「準靜止鋒」相關的鋒面結構，代表不同性質氣團之交界及其伴隨天氣變化。","source_url":"https://glossary.ametsoc.org/wiki/quasi-stationary_front"},{"english":"quasi-stationary perturbation","traditional_chinese":"準穩態擾動","definition_cht":"「quasi-stationary perturbation」為用於描述近似、準平衡或準週期性特徵的專業術語，常見於大氣動力、統計分析與地球系統理論之中。","source_url":"https://glossary.ametsoc.org/wiki/quasi-stationary_perturbation"},{"english":"quasigeostrophic","traditional_chinese":"準地轉的","definition_cht":"「quasigeostrophic」為用於描述近似、準平衡或準週期性特徵的專業術語，常見於大氣動力、統計分析與地球系統理論之中。","source_url":"https://glossary.ametsoc.org/wiki/quasigeostrophic"},{"english":"quasigeostrophic approximation","traditional_chinese":"準地轉近似","definition_cht":"在中高緯度大尺度運動中，假設流場接近地轉平衡並保留主要擾動項的動力近似。","source_url":"https://glossary.ametsoc.org/wiki/quasigeostrophic_approximation"},{"english":"quasigeostrophic current","traditional_chinese":"準地轉流","definition_cht":"指與「準地轉流」相關的海流、氣流或水體輸送現象，著重其流向、來源、結構與輸送作用。","source_url":"https://glossary.ametsoc.org/wiki/quasigeostrophic_current"},{"english":"quasigeostrophic equations","traditional_chinese":"準地轉方程組","definition_cht":"描述接近地轉平衡之大尺度大氣運動的方程組，廣用於中緯度天氣系統診斷與理論分析。","source_url":"https://glossary.ametsoc.org/wiki/quasigeostrophic_equations"},{"english":"quasigeostrophic equilibrium","traditional_chinese":"準地轉平衡","definition_cht":"指與「準地轉平衡」相關的平衡狀態，表示系統中主要力、通量或熱力過程達相對穩定配置。","source_url":"https://glossary.ametsoc.org/wiki/quasigeostrophic_equilibrium"},{"english":"quasigeostrophic motion","traditional_chinese":"準地轉運動","definition_cht":"指與「準地轉運動」相關的運動型態、運移過程或流體動力特徵。","source_url":"https://glossary.ametsoc.org/wiki/quasigeostrophic_motion"},{"english":"quasigeostrophic theory","traditional_chinese":"準地轉理論","definition_cht":"以地轉平衡為基礎並考慮小幅偏離的動力理論架構，是研究中緯度大尺度環流與擾動演變的重要工具。","source_url":"https://glossary.ametsoc.org/wiki/quasigeostrophic_theory"},{"english":"quasiperiodic","traditional_chinese":"準週期的","definition_cht":"指變化具有近似週期性但週期長度或振幅並非完全固定的特性。","source_url":"https://glossary.ametsoc.org/wiki/quasiperiodic"},{"english":"Quaternary climate","traditional_chinese":"第四紀氣候","definition_cht":"指第四紀期間地球氣候的整體狀態與變遷特徵，包含冰期—間冰期循環及其環境回應。","source_url":"https://glossary.ametsoc.org/wiki/Quaternary_climate"},{"english":"Quaternary period","traditional_chinese":"第四紀","definition_cht":"地質年代中最新的一個紀，包括更新世與全新世，常與冰期循環、人類演化及近代環境變遷研究相關。","source_url":"https://glossary.ametsoc.org/wiki/Quaternary_period"},{"english":"quintile","traditional_chinese":"五分位數","definition_cht":"將一組排序資料平均分為五等分時所形成的分位界值或分組概念，常用於氣候統計與機率分級分析。","source_url":"https://glossary.ametsoc.org/wiki/quintile"}]