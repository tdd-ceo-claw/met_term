[
  {
    "english": "K changes",
    "traditional_chinese": "K 變化",
    "definition_cht": "雷電學中指閃電放電期間所出現的一系列短暫、幅度較小的電場或磁場跳變，通常與雲內既有通道的再活化有關。",
    "source_url": "https://glossary.ametsoc.org/wiki/K_changes"
  },
  {
    "english": "K index (space weather)",
    "traditional_chinese": "K 指數（太空天氣）",
    "definition_cht": "以準對數分級表示單一地磁觀測站在三小時內地磁擾動強度的地方性指數，用於評估近地太空環境受太陽活動影響的程度。",
    "source_url": "https://glossary.ametsoc.org/wiki/K_index_(space_weather)"
  },
  {
    "english": "K process",
    "traditional_chinese": "K 過程",
    "definition_cht": "雷電學中指沿既有雲內放電通道再次活化並向前推進的短程擊穿過程，常被視為 K 變化在放電通道上的對應現象。",
    "source_url": "https://glossary.ametsoc.org/wiki/K_process"
  },
  {
    "english": "K'' theory",
    "traditional_chinese": "K'' 理論",
    "definition_cht": "邊界層與紊流參數化中，以渦動交換係數表示湍流輸送的理論框架；常用於描述動量、熱量與水氣的垂直混合作用。",
    "source_url": "https://glossary.ametsoc.org/wiki/K%27%27_theory"
  },
  {
    "english": "k''–ε closure",
    "traditional_chinese": "k''–ε 閉合",
    "definition_cht": "紊流閉合的一種形式，以紊流動能及其耗散率等量來估算渦黏滯與混合強度，用於邊界層與數值模式參數化。",
    "source_url": "https://glossary.ametsoc.org/wiki/k%27%27%E2%80%93%CE%B5_closure"
  },
  {
    "english": "kaavie",
    "traditional_chinese": "卡維風",
    "definition_cht": "地方性風名，指特定區域受地形與季節性壓力分布控制而形成的局地風；具體特徵須依原始地理用法判定。",
    "source_url": "https://glossary.ametsoc.org/wiki/kaavie"
  },
  {
    "english": "kachchan",
    "traditional_chinese": "卡昌風",
    "definition_cht": "地方性風名，多指某些地區出現的乾熱風或挾沙塵的局地風；具體性質依原始區域定義而異。",
    "source_url": "https://glossary.ametsoc.org/wiki/kachchan"
  },
  {
    "english": "Kaikias",
    "traditional_chinese": "凱基阿斯風",
    "definition_cht": "古希臘風系中的風名之一，通常指東北至北北東方向的風，常見於古典地理與歷史氣象記述。",
    "source_url": "https://glossary.ametsoc.org/wiki/Kaikias"
  },
  {
    "english": "kal Baisakhi",
    "traditional_chinese": "卡爾拜薩基暴風",
    "definition_cht": "印度東部與孟加拉前季風期常見的強對流暴風雨，通常伴隨雷電、陣風、短時強降雨，局部並可出現冰雹。",
    "source_url": "https://glossary.ametsoc.org/wiki/kal_Baisakhi"
  },
  {
    "english": "kaléma",
    "traditional_chinese": "卡雷馬霧",
    "definition_cht": "安哥拉沿岸對海霧或近海低雲籠罩現象的地方稱呼，通常與本格拉寒流、近海逆溫及穩定海洋邊界層有關。",
    "source_url": "https://glossary.ametsoc.org/wiki/kal%C3%A9ma"
  },
  {
    "english": "Kalman–Bucy filter",
    "traditional_chinese": "卡爾曼－布希濾波器",
    "definition_cht": "卡爾曼濾波在連續時間系統中的形式，利用動態模式與連續或高頻觀測遞迴估計系統狀態及其誤差協方差，常用於資料同化與控制問題。",
    "source_url": "https://glossary.ametsoc.org/wiki/Kalman%E2%80%93Bucy_filter"
  },
  {
    "english": "Kamchatka Current",
    "traditional_chinese": "堪察加海流",
    "definition_cht": "沿堪察加半島外海向西南流動的寒流，位於白令海與西北太平洋之間，並與親潮水系相連，對高緯海域熱鹽結構與生態環境具重要影響。",
    "source_url": "https://glossary.ametsoc.org/wiki/Kamchatka_Current"
  },
  {
    "english": "kanat",
    "traditional_chinese": "坎兒井",
    "definition_cht": "又作 qanat，指以地下導水隧道與豎井將含水層或井水引至地表的傳統供水系統，可降低乾燥區輸水時的蒸發損失。",
    "source_url": "https://glossary.ametsoc.org/wiki/kanat"
  },
  {
    "english": "karaburan",
    "traditional_chinese": "卡拉布蘭風",
    "definition_cht": "中亞與鄰近乾旱區的地方風名，常指伴隨強風、低能見度與沙塵的惡劣天氣；在部分地區亦可指寒冷而猛烈的暴風現象。",
    "source_url": "https://glossary.ametsoc.org/wiki/karaburan"
  },
  {
    "english": "karajol",
    "traditional_chinese": "卡拉卓爾風",
    "definition_cht": "保加利亞沿岸的地方風名，為離岸西風，常出現在降雨之後，並可持續一至三日。",
    "source_url": "https://glossary.ametsoc.org/wiki/karajol"
  },
  {
    "english": "karema wind",
    "traditional_chinese": "卡雷馬風",
    "definition_cht": "非洲坦干依喀湖上的猛烈東風之地方名稱，常使湖面風浪迅速增強，對航行與湖岸天氣有顯著影響。",
    "source_url": "https://glossary.ametsoc.org/wiki/karema_wind"
  },
  {
    "english": "karif",
    "traditional_chinese": "卡里夫季",
    "definition_cht": "kharif 的另一拼寫，指南亞夏季季風雨季對應的農作季，作物多在雨季開始時播種，並於秋季前後收成。",
    "source_url": "https://glossary.ametsoc.org/wiki/karif"
  },
  {
    "english": "karst",
    "traditional_chinese": "喀斯特地形",
    "definition_cht": "可溶性岩石（如石灰岩、白雲岩）經長期溶蝕作用形成的地貌系統，常見落水洞、溶洞、地下河、窪地等特徵。",
    "source_url": "https://glossary.ametsoc.org/wiki/karst"
  },
  {
    "english": "karst hydrology",
    "traditional_chinese": "喀斯特水文學",
    "definition_cht": "研究喀斯特地區降水入滲、地下導水通道、泉水出流、地下水儲集與快速逕流反應等過程的水文學分支。",
    "source_url": "https://glossary.ametsoc.org/wiki/karst_hydrology"
  },
  {
    "english": "karstbora",
    "traditional_chinese": "喀斯特布拉風",
    "definition_cht": "發生於喀斯特高原或石灰岩地區的布拉型下坡強風，通常由冷密空氣越嶺外洩並受地形加速所致。",
    "source_url": "https://glossary.ametsoc.org/wiki/karstbora"
  },
  {
    "english": "katabatic front",
    "traditional_chinese": "下降風鋒",
    "definition_cht": "由冷而密的下坡氣流向外推進時，在其前緣形成的淺薄鋒面或鋒狀邊界，常見於冰原、冰棚或山區出流附近。",
    "source_url": "https://glossary.ametsoc.org/wiki/katabatic_front"
  },
  {
    "english": "katabatic wind",
    "traditional_chinese": "下坡風",
    "definition_cht": "由重力驅動的冷密空氣沿山坡、冰蓋或高原邊坡向低處流動之風，常由地表輻射冷卻增密所觸發，為典型的下降風。",
    "source_url": "https://glossary.ametsoc.org/wiki/katabatic_wind"
  },
  {
    "english": "katafront",
    "traditional_chinese": "下降型鋒面",
    "definition_cht": "鋒面分析中指暖空氣相對鋒面呈下沉運動的鋒面型態，降水常貼近鋒面或位於其後側，與上升型鋒面相對。",
    "source_url": "https://glossary.ametsoc.org/wiki/katafront"
  },
  {
    "english": "katallobaric",
    "traditional_chinese": "負變壓的",
    "definition_cht": "指氣壓隨時間下降的狀態、區域或效應；在動力氣象中常用以描述由壓力下降所伴生的風場加速度影響。",
    "source_url": "https://glossary.ametsoc.org/wiki/katallobaric"
  },
  {
    "english": "katathermometer",
    "traditional_chinese": "冷卻溫度計",
    "definition_cht": "用以測量環境空氣冷卻能力的溫度計，通常依加熱後的降溫速率估算空氣流動、溫度與濕度對散熱的綜合作用。",
    "source_url": "https://glossary.ametsoc.org/wiki/katathermometer"
  },
  {
    "english": "kaus",
    "traditional_chinese": "考斯風",
    "definition_cht": "古典或地方風名之一；現代標準氣象文獻對其定義較少，通常保留作歷史風名使用。",
    "source_url": "https://glossary.ametsoc.org/wiki/kaus"
  },
  {
    "english": "kelsher",
    "traditional_chinese": "凱爾舍雨",
    "definition_cht": "英格蘭西南部方言中的天氣用語，指一陣很大的雨或傾盆大雨。",
    "source_url": "https://glossary.ametsoc.org/wiki/kelsher"
  },
  {
    "english": "Kelvin temperature scale",
    "traditional_chinese": "克耳文溫標",
    "definition_cht": "以絕對零度為零點的熱力學溫標，單位為克耳文，與攝氏溫標的刻度間距相同，但不使用「度」作單位名稱。",
    "source_url": "https://glossary.ametsoc.org/wiki/Kelvin_temperature_scale"
  },
  {
    "english": "Kelvin wave",
    "traditional_chinese": "克耳文波",
    "definition_cht": "受地球自轉影響，並由海岸、湖岸或赤道等邊界／波導所束縛的重力波；其重要特徵之一是不具頻散性，能量與波形可沿邊界傳播而較易維持。",
    "source_url": "https://glossary.ametsoc.org/wiki/Kelvin_wave"
  },
  {
    "english": "Kelvin–Helmholtz billows",
    "traditional_chinese": "開爾文－赫姆霍茲波狀翻捲",
    "definition_cht": "由垂直風切變或層間速度差觸發的開爾文－赫姆霍茲不穩定所形成之捲曲波狀結構；在大氣中常呈現在雲頂的一連串翻捲浪形。",
    "source_url": "https://glossary.ametsoc.org/wiki/Kelvin%E2%80%93Helmholtz_billows"
  },
  {
    "english": "Kelvin–Helmholtz instability",
    "traditional_chinese": "開爾文－赫姆霍茲不穩定",
    "definition_cht": "流體中因明顯速度切變，或兩層流體交界面存在速度差而產生的動力不穩定；可使波動振幅增長，並進一步促進混合與紊流發展。",
    "source_url": "https://glossary.ametsoc.org/wiki/Kelvin%E2%80%93Helmholtz_instability"
  },
  {
    "english": "Kelvin–Helmholtz wave",
    "traditional_chinese": "開爾文－赫姆霍茲波",
    "definition_cht": "由層間速度切變所激發的界面波或雲波，為開爾文－赫姆霍茲不穩定在大氣或海洋中的典型表現。",
    "source_url": "https://glossary.ametsoc.org/wiki/Kelvin%E2%80%93Helmholtz_wave"
  },
  {
    "english": "kernel ice",
    "traditional_chinese": "粒核冰",
    "definition_cht": "由細小冰核或粒狀冰晶聚集形成的冰體，常用以描述冰晶初始成長階段或顆粒狀冰質結構。",
    "source_url": "https://glossary.ametsoc.org/wiki/kernel_ice"
  },
  {
    "english": "ketones",
    "traditional_chinese": "酮類",
    "definition_cht": "含有羰基（>C=O）的一類有機化合物；在大氣化學中可作為揮發性有機物氧化後的產物或反應中間體，並影響氧化能力與有機氣膠生成。",
    "source_url": "https://glossary.ametsoc.org/wiki/ketones"
  },
  {
    "english": "Kew barometer",
    "traditional_chinese": "丘式氣壓計",
    "definition_cht": "依英國 Kew Observatory 標準製作與校正的水銀氣壓計，歷史上廣用於精密氣壓觀測與儀器比對。",
    "source_url": "https://glossary.ametsoc.org/wiki/Kew_barometer"
  },
  {
    "english": "khamsin",
    "traditional_chinese": "哈姆辛風",
    "definition_cht": "春季常見於埃及及鄰近地區的乾熱多塵風，通常來自沙漠內陸，伴隨高溫、低濕與能見度惡化。",
    "source_url": "https://glossary.ametsoc.org/wiki/khamsin"
  },
  {
    "english": "killing freeze",
    "traditional_chinese": "致害霜凍",
    "definition_cht": "足以造成作物、嫩芽或其他植物組織嚴重凍傷甚至死亡的低溫霜凍事件。",
    "source_url": "https://glossary.ametsoc.org/wiki/killing_freeze"
  },
  {
    "english": "kilocalorie",
    "traditional_chinese": "千卡",
    "definition_cht": "熱量單位，等於一千卡路里，傳統上表示使一公斤水升高攝氏一度所需之熱量，常用於能量收支與熱力換算。",
    "source_url": "https://glossary.ametsoc.org/wiki/kilocalorie"
  },
  {
    "english": "kilocycle",
    "traditional_chinese": "千周",
    "definition_cht": "舊制頻率單位，表示每秒一千次振動，現多以 kilohertz 取代。",
    "source_url": "https://glossary.ametsoc.org/wiki/kilocycle"
  },
  {
    "english": "kilogram calorie",
    "traditional_chinese": "公斤卡",
    "definition_cht": "以一公斤水升高攝氏一度所需熱量定義的傳統熱量單位，數值上等同於千卡。",
    "source_url": "https://glossary.ametsoc.org/wiki/kilogram_calorie"
  },
  {
    "english": "kilohertz",
    "traditional_chinese": "千赫",
    "definition_cht": "頻率單位，等於每秒一千赫茲，常用於無線電、雷達與電子訊號之頻譜描述。",
    "source_url": "https://glossary.ametsoc.org/wiki/kilohertz"
  },
  {
    "english": "kilojoule",
    "traditional_chinese": "千焦耳",
    "definition_cht": "能量單位，等於一千焦耳，為國際單位制中常用之熱量與功的表示方式。",
    "source_url": "https://glossary.ametsoc.org/wiki/kilojoule"
  },
  {
    "english": "kilomegacycle",
    "traditional_chinese": "十億周（舊制）",
    "definition_cht": "舊制頻率單位，等於每秒十億次振動，即 10^9 cycles per second，現多以 gigahertz（GHz）表示。",
    "source_url": "https://glossary.ametsoc.org/wiki/kilomegacycle"
  },
  {
    "english": "kilomole",
    "traditional_chinese": "千莫耳",
    "definition_cht": "物質量單位，等於一千莫耳，常用於大氣化學、燃燒與工程熱力學的大尺度計算。",
    "source_url": "https://glossary.ametsoc.org/wiki/kilomole"
  },
  {
    "english": "kinematic boundary condition",
    "traditional_chinese": "運動學邊界條件",
    "definition_cht": "流體邊界上質點不得穿越邊界的條件，常表為邊界法向速度與邊界位移變化相容，用於自由液面、地表或等壓面分析。",
    "source_url": "https://glossary.ametsoc.org/wiki/kinematic_boundary_condition"
  },
  {
    "english": "kinematic flux",
    "traditional_chinese": "運動學通量",
    "definition_cht": "未乘上密度、比熱或潛熱等轉換係數前的通量表示法，常以垂直速度與某標量擾動的協方差表示，用於紊流熱量、水氣或動量交換分析。",
    "source_url": "https://glossary.ametsoc.org/wiki/kinematic_flux"
  },
  {
    "english": "kinematic viscosity",
    "traditional_chinese": "動黏滯係數",
    "definition_cht": "流體之動力黏度除以密度所得的黏滯量，表示動量擴散能力，常用單位為平方公尺每秒。",
    "source_url": "https://glossary.ametsoc.org/wiki/kinematic_viscosity"
  },
  {
    "english": "kinematical analysis",
    "traditional_chinese": "運動學分析",
    "definition_cht": "依據風場幾何與速度分布，分析散度、渦度、變形與垂直運動等運動特徵的方法，不直接涉及動力成因。",
    "source_url": "https://glossary.ametsoc.org/wiki/kinematical_analysis"
  },
  {
    "english": "kinematics",
    "traditional_chinese": "運動學",
    "definition_cht": "研究流體或物體運動之速度、位移、加速度與變形關係的學科，不涉及造成運動的力學來源。",
    "source_url": "https://glossary.ametsoc.org/wiki/kinematics"
  },
  {
    "english": "kinetic energy",
    "traditional_chinese": "動能",
    "definition_cht": "物體或流體因運動所具有的能量，在大氣中常用以描述平均流、紊流與擾動系統之能量狀態。",
    "source_url": "https://glossary.ametsoc.org/wiki/kinetic_energy"
  },
  {
    "english": "kinetic theory",
    "traditional_chinese": "氣體動力論",
    "definition_cht": "以大量微觀粒子的隨機運動與碰撞之統計性質，說明氣體壓力、溫度及輸送現象的理論基礎。",
    "source_url": "https://glossary.ametsoc.org/wiki/kinetic_theory"
  },
  {
    "english": "Kirchhoff vortex",
    "traditional_chinese": "基爾霍夫渦旋",
    "definition_cht": "理論流體力學中的一類橢圓形均勻渦度渦旋解，可用於研究二維旋轉渦體之穩定性與演變。",
    "source_url": "https://glossary.ametsoc.org/wiki/Kirchhoff_vortex"
  },
  {
    "english": "Kirchhoff's equation",
    "traditional_chinese": "基爾霍夫方程",
    "definition_cht": "流體力學中描述剛體在理想流體內平移與轉動運動的方程組；常用於分析浸沒物體所受流體力與力矩。",
    "source_url": "https://glossary.ametsoc.org/wiki/Kirchhoff%27s_equation"
  },
  {
    "english": "Kirchhoff's law",
    "traditional_chinese": "基爾霍夫定律",
    "definition_cht": "熱輻射理論中指在熱平衡下物體於某波長的放射能力與吸收能力具有固定關係，為大氣輻射傳輸的重要基礎。",
    "source_url": "https://glossary.ametsoc.org/wiki/Kirchhoff%27s_law"
  },
  {
    "english": "kite observation",
    "traditional_chinese": "風箏觀測",
    "definition_cht": "利用繫留風箏攜帶儀器進行近地層或低空氣象觀測的方法，歷史上曾用於測量溫度、濕度、風與壓力。",
    "source_url": "https://glossary.ametsoc.org/wiki/kite_observation"
  },
