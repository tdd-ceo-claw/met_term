[{"english":"Z time","traditional_chinese":"祖魯時間","definition_cht":"指以零時區為基準的世界標準時間表示法，實務上通常等同於 UTC，常用於航空、航海與氣象作業。","source_url":"https://glossary.ametsoc.org/wiki/Z_time"},{"english":"Z''–''R'' relation","traditional_chinese":"雷達反射率—降雨率關係","definition_cht":"指雷達反射率因子 Z 與降雨率 R 之間的經驗或理論關係，用於由雷達回波估算降雨強度。","source_url":"https://glossary.ametsoc.org/wiki/Z%27%27%E2%80%93%27%27R%27%27_relation"},{"english":"Z0","traditional_chinese":"粗糙度長度","definition_cht":"在邊界層氣象中，指對數風速剖面外推至風速為零時所對應的理論高度，用來表徵地表粗糙程度。","source_url":"https://glossary.ametsoc.org/wiki/Z0"},{"english":"Zanzibar Current","traditional_chinese":"桑吉巴洋流","definition_cht":"指東非桑吉巴附近海域的區域性洋流，反映當地季風、海岸地形與西印度洋環流特徵。","source_url":"https://glossary.ametsoc.org/wiki/Zanzibar_Current"},{"english":"zastrugi","traditional_chinese":"風蝕雪脊","definition_cht":"指積雪表面在強風侵蝕與再堆積作用下形成的狹長硬雪脊或溝槽地形。","source_url":"https://glossary.ametsoc.org/wiki/zastrugi"},{"english":"Zeeman effect","traditional_chinese":"塞曼效應","definition_cht":"指原子或分子光譜線在外加磁場作用下發生分裂的現象，可用於研究磁場性質。","source_url":"https://glossary.ametsoc.org/wiki/Zeeman_effect"},{"english":"Zeldovich mechanism","traditional_chinese":"澤爾多維奇機制","definition_cht":"指高溫條件下生成氮氧化物的重要化學反應機制，常用於燃燒與大氣化學研究。","source_url":"https://glossary.ametsoc.org/wiki/Zeldovich_mechanism"},{"english":"zenith","traditional_chinese":"天頂","definition_cht":"指觀測者正上方天球上的點，為地平座標系中的重要基準方向。","source_url":"https://glossary.ametsoc.org/wiki/zenith"},{"english":"zenith distance","traditional_chinese":"天頂距","definition_cht":"指天體或目標與天頂之間的角距離，等於 90 度減去其高度角。","source_url":"https://glossary.ametsoc.org/wiki/zenith_distance"},{"english":"zenithal rains","traditional_chinese":"天頂雨","definition_cht":"指太陽接近天頂時，由強烈對流發展而產生的降雨，常見於熱帶地區。","source_url":"https://glossary.ametsoc.org/wiki/zenithal_rains"},{"english":"zephyr","traditional_chinese":"和風","definition_cht":"指微弱而柔和的風，多用於描述輕風或文學性的大氣流動意象。","source_url":"https://glossary.ametsoc.org/wiki/zephyr"},{"english":"Zephyros","traditional_chinese":"西風之神","definition_cht":"源自古希臘神話中代表西風的神名，延伸用來象徵溫和西風。","source_url":"https://glossary.ametsoc.org/wiki/Zephyros"},{"english":"zero curtain","traditional_chinese":"零度幕","definition_cht":"指土壤或積雪在結冰或融化過程中，溫度長時間維持在接近 0°C 的現象。","source_url":"https://glossary.ametsoc.org/wiki/zero_curtain"},{"english":"zero layer","traditional_chinese":"零層","definition_cht":"指緊貼地表、可近似視為平均風速趨近於零的極薄層。","source_url":"https://glossary.ametsoc.org/wiki/zero_layer"},{"english":"zero-order closure","traditional_chinese":"零階閉合","definition_cht":"指在參數化中不顯式表示高階擾動通量，只以最簡化假設處理次網格效應的方法。","source_url":"https://glossary.ametsoc.org/wiki/zero-order_closure"},{"english":"zero-plane displacement","traditional_chinese":"零平面位移","definition_cht":"指在高糙度下墊面上，對數風速剖面所對應的位移高度，用以反映植被或建築物對流場的抬升效應。","source_url":"https://glossary.ametsoc.org/wiki/zero-plane_displacement"},{"english":"zero-pressure balloon","traditional_chinese":"零壓氣球","definition_cht":"指內部氣壓與外界大氣近乎相同、可隨高度膨脹的高空探測氣球。","source_url":"https://glossary.ametsoc.org/wiki/zero-pressure_balloon"},{"english":"zigzag lightning","traditional_chinese":"鋸齒狀閃電","definition_cht":"指通道呈明顯折線或曲折形態的閃電。","source_url":"https://glossary.ametsoc.org/wiki/zigzag_lightning"},{"english":"zobaa","traditional_chinese":"佐巴風暴","definition_cht":"阿拉伯語系地區對沙塵暴或強旋風性風暴的稱呼。","source_url":"https://glossary.ametsoc.org/wiki/zobaa"},{"english":"zodiac","traditional_chinese":"黃道帶","definition_cht":"指天球上沿黃道分布的帶狀區域，傳統上與黃道十二宮相關。","source_url":"https://glossary.ametsoc.org/wiki/zodiac"},{"english":"zodiacal band","traditional_chinese":"黃道帶光帶","definition_cht":"指沿黃道分布、由行星際塵埃散射太陽光形成的微弱光帶。","source_url":"https://glossary.ametsoc.org/wiki/zodiacal_band"},{"english":"zodiacal light","traditional_chinese":"黃道光","definition_cht":"指日出前或日落後沿黃道方向可見、由行星際塵埃散射太陽光形成的微弱輝光。","source_url":"https://glossary.ametsoc.org/wiki/zodiacal_light"},{"english":"zombie turbulence","traditional_chinese":"殭屍湍流","definition_cht":"指在原有湍流衰減後，受重力波或層結作用再度被激發的次級湍流現象。","source_url":"https://glossary.ametsoc.org/wiki/zombie_turbulence"},{"english":"zonal","traditional_chinese":"緯向的","definition_cht":"指沿緯圈方向，也就是由西向東或由東向西的方向特性。","source_url":"https://glossary.ametsoc.org/wiki/zonal"},{"english":"zonal flow","traditional_chinese":"緯向流","definition_cht":"指以東西向分量為主的大氣或海洋流動。","source_url":"https://glossary.ametsoc.org/wiki/zonal_flow"},{"english":"zonal index","traditional_chinese":"緯向指數","definition_cht":"用來衡量大氣環流中緯向流強弱或經向擾動程度的指標。","source_url":"https://glossary.ametsoc.org/wiki/zonal_index"},{"english":"zonal kinetic energy","traditional_chinese":"緯向動能","definition_cht":"指與緯向流動有關的動能分量。","source_url":"https://glossary.ametsoc.org/wiki/zonal_kinetic_energy"},{"english":"zonal wavenumber","traditional_chinese":"緯向波數","definition_cht":"指波動沿緯向方向的空間波數，用於描述行星波或其他大尺度擾動。","source_url":"https://glossary.ametsoc.org/wiki/zonal_wavenumber"},{"english":"zonal wind","traditional_chinese":"緯向風","definition_cht":"指沿東西方向吹送的風，其正負常用以區分西風與東風分量。","source_url":"https://glossary.ametsoc.org/wiki/zonal_wind"},{"english":"zonal wind-speed profile","traditional_chinese":"緯向風速剖面","definition_cht":"指緯向風速隨高度、緯度或其他空間座標變化的分布。","source_url":"https://glossary.ametsoc.org/wiki/zonal_wind-speed_profile"},{"english":"zonality of hydrological phenomena","traditional_chinese":"水文現象的帶狀性","definition_cht":"指水文要素或過程隨緯度帶呈現規律性分布的特徵。","source_url":"https://glossary.ametsoc.org/wiki/zonality_of_hydrological_phenomena"},{"english":"zonally averaged models","traditional_chinese":"緯向平均模式","definition_cht":"指先對緯向方向取平均，再描述氣候或大氣狀態演變的理論或數值模式。","source_url":"https://glossary.ametsoc.org/wiki/zonally_averaged_models"},{"english":"zonda","traditional_chinese":"宗達風","definition_cht":"指阿根廷安地斯山東側常見的乾熱下坡風，類似焚風性質。","source_url":"https://glossary.ametsoc.org/wiki/zonda"},{"english":"zone of aeration","traditional_chinese":"通氣帶","definition_cht":"指地下水位以上、孔隙中同時含有空氣與水分的土層或地層。","source_url":"https://glossary.ametsoc.org/wiki/zone_of_aeration"},{"english":"zone of maximum precipitation","traditional_chinese":"最大降水帶","definition_cht":"指降水量或降水頻率最為集中的區域。","source_url":"https://glossary.ametsoc.org/wiki/zone_of_maximum_precipitation"},{"english":"zone of saturation","traditional_chinese":"飽和帶","definition_cht":"指地下水位以下、孔隙幾乎完全被水充滿的地層。","source_url":"https://glossary.ametsoc.org/wiki/zone_of_saturation"},{"english":"zone of silence","traditional_chinese":"靜區","definition_cht":"指某些波動、聲音或電磁訊號因折射、遮蔽或干涉而無法有效到達的區域。","source_url":"https://glossary.ametsoc.org/wiki/zone_of_silence"},{"english":"zone time","traditional_chinese":"區時","definition_cht":"指以特定時區中央經線為基準所採用的標準時間。","source_url":"https://glossary.ametsoc.org/wiki/zone_time"},{"english":"zone wind","traditional_chinese":"帶狀風","definition_cht":"指沿某一氣候或環流帶內具有代表性的風系，常泛指緯向主導的風場。","source_url":"https://glossary.ametsoc.org/wiki/zone_wind"}]